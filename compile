#!/usr/bin/env bash
set -euo pipefail

BUILD_TYPE="Debug"
BUILD_DIR="build"
REBUILD=0
TARGET="firmware"
CMAKE_TARGET=""
INSTALL=0

usage() {
    cat <<'EOF'
Usage: ./compile [--target <name>] [--release|--debug] [--rebuild] [--install]

Examples:
    ./compile
    ./compile --target sensor
    ./compile --target radio --release
    ./compile --rebuild
    ./compile --target sensor --install

Rules:
    - If --target is not provided, build all targets.
  - Default build mode is Debug.
  - --release switches to Release mode.
        - --rebuild removes the existing build directory before configuring.
        - --install runs install_target after build (requires --target).
    - --target values are mapped to CMake target names.
        Example: radio => leos-radio
EOF
}

stage() {
    printf "==> $1\n"
}


update_submodules() {
    stage "Updating Submodules"
    git submodule update --init --recursive
}

remove_build_dir() {
    stage "Rebuild requested: removing build directory..."
    rm -rf "$BUILD_DIR"
    mkdir -p "$BUILD_DIR"
}

reuse_build_dir() {
    stage "Reusing existing build directory (use --rebuild for a clean build)..."
    mkdir -p "$BUILD_DIR"
}

fetch_pico_sdk_from_git() {
    export PICO_SDK_FETCH_FROM_GIT=1
}

ensure_pico_sdk() {
    stage "Find Pico SDK"
    if [ -z "${PICO_SDK_PATH}" ]; then
        echo "PICO_SDK_PATH is not set."
        echo "The pico-sdk will be fetched from git."
        echo
        echo "Note: It is recommended to download the pico-sdk somewhere on your computer"
        echo "and set the PICO_SDK_PATH environment variable to avoid repeated downloads from git."
        fetch_pico_sdk_from_git
    elif [ ! -d "${PICO_SDK_PATH}" ]; then
        echo "PICO_SDK_PATH is set but the directory does not exist:"
        echo "  ${PICO_SDK_PATH}"
        exit 1
    else
        echo "Using pico-sdk at: ${PICO_SDK_PATH}"
    fi
}

configure_cmake() {
    stage "Configuring CMake..."
    cmake -S . -B "$BUILD_DIR" -G Ninja \
        -DCMAKE_BUILD_TYPE="$BUILD_TYPE" \
        -DCMAKE_MESSAGE_LOG_LEVEL=WARNING
}

compile() {
    if [[ "$TARGET" == "all" ]]; then
        stage "Compiling all targets..."
    else
        stage "Compiling target $CMAKE_TARGET"
    fi
    cmake --build "$BUILD_DIR" --parallel --target "$CMAKE_TARGET"

}

install_target() {
    stage "Running install_target"
    picotool load "build/firmware/$1.uf2"
    picotool reboot
}

# Use short name for board targets
map_target() {
    echo "leos-$1"
}


while (($#)); do
    case "$1" in
                --target)
                        if (($# < 2)); then
                                echo "Error: --target requires a value"
                                usage
                                exit 1
                        fi
                        TARGET="$2"
                        shift 2
                        ;;
        --release)
            BUILD_TYPE="Release"
            shift
            ;;
        --debug)
            BUILD_TYPE="Debug"
            shift
            ;;
        --rebuild)
            REBUILD=1
            shift
            ;;
        --install)
            INSTALL=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --*)
            echo "Error: unknown option '$1'"
            usage
            exit 1
            ;;
        *)
            echo "Error: unknown argument '$1'"
            usage
            exit 1
            ;;
    esac
done

# Build system

stage "Starting Build..."
printf "    Build Mode: $BUILD_TYPE\n"
printf "    Build Directory: $BUILD_DIR\n"

update_submodules

if [[ -n "$TARGET" && "$TARGET" != "tools" && "$TARGET" != "firmware" && "$TARGET" != "all" ]]; then
    CMAKE_TARGET="$(map_target "$TARGET")"
else
    CMAKE_TARGET="$TARGET"
fi

if [[ "$INSTALL" -eq 1 && "$TARGET" == "all" ]]; then
    echo "Error: --install requires --target <name>"
    usage
    exit 1
fi

if [[ "$REBUILD" -eq 1 ]]; then
    remove_build_dir
else
    reuse_build_dir
fi

ensure_pico_sdk
configure_cmake
compile

if [[ "$INSTALL" -eq 1 ]]; then
    install_target $CMAKE_TARGET
fi

stage "Done."
